[0m13:14:09.897866 [debug] [Thread-3 (]: On model.dbt_tutorial.mart_sales_info: /* {"app": "dbt", "dbt_version": "1.11.8", "dbt_databricks_version": "1.11.8", "databricks_sql_connector_version": "4.1.5", "profile_name": "dbt_tutorial", "target_name": "dev", "invocation_id": "075c4b06-924e-4fb1-98a5-6af229257195", "node_id": "model.dbt_tutorial.mart_sales_info"} */

  
  
  create or replace view `dbt_tutorial_dev`.`default`.`mart_sales_info`
  
  as (
    with sales as
(
    select
        sales_id,
        product_sk,
        customer_sk,
        date_sk,
        gross_amount,
        net_amount,
        payment_method,
        

(quantity*unit_price)


 as calc_gross_amount

    FROM
        `dbt_tutorial_dev`.`default`.`stg_sales`
),

products as 
(
    Select
        product_sk,
        product_name,
        department,
        category,
        list_price

    FROM
        `dbt_tutorial_dev`.`default`.`stg_products`

),

customers as 
(
    select 
        customer_sk,
        customer_code,
        loyalty_tier,
        gender

    FROM
        `dbt_tutorial_dev`.`default`.`stg_customers`
),

sales_query as 
(
    select
        sales.sales_id,
        sales.product_sk,
        sales.customer_sk,
        sales.date_sk,
        sales.gross_amount,
        sales.net_amount,
        sales.payment_method,
        sales.calc_gross_amount,
        products.product_name,
        products.department,
        products.category,
        products.list_price,
        customers.customer_code,
        customers.loyalty_tier,
        customers.gender

    FROM
        sales
    JOIN
        products ON sales.product_sk = products.product_sk
    
    JOIN customers ON sales.customer_sk = customers.customer_sk

)

